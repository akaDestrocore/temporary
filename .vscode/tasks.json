{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake --preset Debug",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "CMake: Build All",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset Debug",
            "problemMatcher": "$gcc",
            "group": "build"
        },
        {
            "label": "CMake: Build Bootloader",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset Boot-Debug",
            "problemMatcher": "$gcc",
            "group": "build"
        },
        {
            "label": "CMake: Build Application",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset App-Debug",
            "problemMatcher": "$gcc",
            "group": "build"
        },
        {
            "label": "CMake: Build All",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset Debug",
            "problemMatcher": "$gcc",
            "group": "build"
        },
        {
            "label": "Flash: Full Firmware",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset Debug --target flash",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Flash: Bootloader Only",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset Boot-Debug",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Flash: Application Only",
            "type": "shell",
            "command": "cmake --preset Debug && cmake --build --preset App-Debug --target flash_app",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "CMake: Clean Rebuild",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/build && cmake --preset Debug && cmake --build --preset Debug",
            "problemMatcher": "$gcc",
            "group": "build"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Task generated by Debugger."
        }
    ]
}